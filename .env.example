# ============================================
# BURSA DIVIDEND AGENT — ENV CONFIG
# Copy this to .env and fill in your values
# ============================================

# Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxx

# Your Telegram Chat ID (message @userinfobot to get yours)
TELEGRAM_CHAT_ID=your_chat_id_here

# AI Score threshold — only alert if score >= this (0-10)
# Recommended: 6 (balanced) or 7 (stricter)
SCORE_THRESHOLD=6

# Cron schedule (default: every 5 mins, weekdays 9am-5:30pm KL)
# Format: minute hour day month weekday
CRON_SCHEDULE=*/5 9-17 * * 1-5
